{
  "rules": {
    "devices": {
      ".read": "true",
      "$device_id": {
        ".write": "true"
      }
    },
    "users": {
      "$user_id": {
        ".read": "auth != null && auth.uid == $user_id",
        ".write": "auth != null && auth.uid == $user_id",
        "devices": {
          "$device_id": {
            ".write": "true"
          }
        }
      }
    }
  }
}
